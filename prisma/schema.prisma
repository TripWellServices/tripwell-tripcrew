// Intentional: use DATABASE_PRISMA_DATABASE_URL (Accelerate) for Vercel serverless.
// Do not revert to DATABASE_URL. See docs/DATABASE_AND_VERCEL_PRISMA.md
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_PRISMA_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Single-day vs multi-day trip
enum TripType {
  SINGLE_DAY
  MULTI_DAY
}

enum WhoWith {
  SOLO
  SPOUSE
  FRIENDS
  FAMILY
  OTHER
}

enum TransportMode {
  CAR
  BOAT
  PLANE
}

enum TripDayExperienceStatus {
  PLANNED
  CANCELLED
  COMPLETE
}

// Stuff-to-do catalogue entry type (OG CityStuffToDo buckets).
enum StuffToDoType {
  POI
  RESTAURANT
  NEAT_THING
}

// Lodging property / stay category (hotel name stays on `title`).
enum LodgingType {
  HOTEL
  RESORT
  EXTENDED_STAY
  VACATION_RENTAL
  HOSTEL
  BED_AND_BREAKFAST
  OTHER
}

// TripWell Enterprises - Master Container (like GoFastCompany)
model TripWellEnterprise {
  id          String   @id @default(uuid())
  name        String   @default("TripWell Enterprises")
  address     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  travelers  Traveler[]  @relation("EnterpriseTravelers")
  lodging    Lodging[]   @relation("EnterpriseLodging")
  dining     Dining[]    @relation("EnterpriseDining")
  attractions Attraction[] @relation("EnterpriseAttractions")
}

// City — first-class place key; optional destination guide copy + citySlug live on same row (merged from CityGuide).
model City {
  id        String  @id @default(uuid())
  citySlug  String? @unique // URL segment for /destinations/[citySlug]; null = catalogue city without a guide page yet
  name      String // e.g. "Boston", "Venice Beach"
  state     String?
  country   String?

  tagline         String?
  description     String?  @db.Text
  bestTimeToVisit String?
  attractionNames String[] @default([])
  imageUrl        String?
  guideCreatedById String?
  guideCreatedBy   Traveler? @relation("CityGuideAuthor", fields: [guideCreatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  destinations   Destination[]
  stuffToDoItems StuffToDoItem[]
  concerts       Concert[]
  hikes          Hike[]
  dining         Dining[]
  attractions    Attraction[]
  sports         Sport[]
  adventures     Adventure[]
  cruises        Cruise[]

  @@unique([name, state, country])
  @@index([name])
  @@index([country])
}

model Traveler {
  id         String  @id @default(uuid())
  firebaseId String? @unique
  email      String? @unique
  firstName  String?
  lastName   String?
  photoURL   String? // Google profile picture URL (from Firebase)

  // Profile fields (from OG TripWell ProfileSetup)
  hometownCity     String?
  homeState        String?
  homeAddress      String? // full street address for drive-time / day plans
  persona          String? // "Art", "Food", "History", "Adventure"
  planningStyle    String? // "Spontaneous", "Mix of spontaneous and planned", "Set a plan and stick to it!"
  dreamDestination String?

  tripWellEnterpriseId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tripWellEnterprise  TripWellEnterprise? @relation("EnterpriseTravelers", fields: [tripWellEnterpriseId], references: [id])
  tripCrewMemberships TripCrewMember[]    @relation("TravelerTripCrewMemberships")
  tripCrewRoles       TripCrewRole[]      @relation("TravelerTripCrewRoles")
  trips               Trip[]              @relation("TravelerTrips")
  wishlist            Wishlist?
  authoredHikes       Hike[]              @relation("HikeAuthor")
  savedHikes          Hike[]              @relation("HikeSavedBy")
  authoredConcerts    Concert[]           @relation("ConcertAuthor")
  savedConcerts       Concert[]           @relation("ConcertSavedBy")
  authoredDining      Dining[]            @relation("DiningAuthor")
  savedDining         Dining[]            @relation("DiningSavedBy")
  authoredAttractions Attraction[]        @relation("AttractionAuthor")
  savedAttractions    Attraction[]        @relation("AttractionSavedBy")
  authoredSports      Sport[]             @relation("SportAuthor")
  savedSports         Sport[]             @relation("SportSavedBy")
  authoredAdventures  Adventure[]         @relation("AdventureAuthor")
  savedAdventures     Adventure[]         @relation("AdventureSavedBy")
  authoredCruises     Cruise[]            @relation("CruiseAuthor")
  savedCruises        Cruise[]            @relation("CruiseSavedBy")
  authoredCities      City[]              @relation("CityGuideAuthor")
  authoredTripMemories TripMemory[]       @relation("TripMemoryAuthor")
  memorySharesSent     TripMemoryShare[]   @relation("TripMemoryShareSender")
}

model TripCrew {
  id       String  @id @default(uuid())
  name     String?
  handle   String? @unique  // GoFast-style: public slug for invite URL (e.g. "boston-crew")
  joinCode String  @unique  // legacy; invite primary = handle

  // Relations
  memberships TripCrewMember[] // Junction table for members
  roles       TripCrewRole[]   // Junction table for admin/manager roles
  trips       Trip[]           // Trips belong to TripCrew
  joinCodes   JoinCode[]      // JoinCode registry (authoritative source for code-based invites)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([joinCode])
  @@index([handle])
}

// Wishlist — one row per traveler (identity / “My list” aggregate); catalogue rows link via wishlistId.
model Wishlist {
  id         String   @id @default(uuid())
  travelerId String   @unique
  name       String
  slug       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  traveler    Traveler     @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  hikes       Hike[]
  concerts    Concert[]
  dining      Dining[]
  attractions Attraction[]
  sports      Sport[]
  adventures  Adventure[]
  cruises     Cruise[]

  @@map("wishlists")
}

// JoinCode Registry - Authoritative source for TripCrew invites
model JoinCode {
  id         String    @id @default(uuid())
  code       String    @unique // Normalized, uppercase code
  tripCrewId String
  tripCrew   TripCrew  @relation(fields: [tripCrewId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  isActive   Boolean   @default(true)

  @@index([code])
  @@index([tripCrewId])
  @@map("join_codes")
}

model Trip {
  id         String  @id @default(uuid())
  crewId     String?
  travelerId String?

  tripType TripType @default(MULTI_DAY)
  purpose  String   @default("")

  city    String?
  state   String?
  country String?

  whoWith          WhoWith?
  transportMode    TransportMode?
  startingLocation String?

  startDate DateTime
  endDate   DateTime
  daysTotal Int
  season    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  crew         TripCrew?  @relation(fields: [crewId], references: [id], onDelete: Cascade)
  traveler     Traveler?  @relation("TravelerTrips", fields: [travelerId], references: [id], onDelete: SetNull)
  destinations Destination[]
  tripDays     TripDay[]
  logistics    LogisticItem[]
  packItems    PackItem[]
  lodging      Lodging?     @relation("TripLodging")
  dining       Dining[]     @relation("TripDining")
  attractions  Attraction[] @relation("TripAttractions")
  memories     TripMemory[]

  @@index([crewId])
  @@index([travelerId])
}

model TripDay {
  id           String   @id @default(uuid())
  tripId       String
  date         DateTime
  dayNumber    Int
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip         Trip                  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  experiences  TripDayExperience[]
  memories     TripMemory[]

  @@unique([tripId, date])
  @@index([tripId])
}

// Trip memory: photos + reflection; optional Trip for freestyle / hindsight entries.
model TripMemory {
  id               String    @id @default(uuid())
  tripId           String?
  authorTravelerId String
  tripDayId        String?
  body             String    @db.Text

  /// When tripId is null — label this memory (e.g. "Portugal 2024"); hindsight stub.
  freestyleTitle    String?
  freestyleCity     String?
  freestyleState    String?
  freestyleCountry  String?
  freestyleStartDate DateTime?
  freestyleEndDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip    Trip?      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  author  Traveler   @relation("TripMemoryAuthor", fields: [authorTravelerId], references: [id], onDelete: Cascade)
  tripDay TripDay?   @relation(fields: [tripDayId], references: [id], onDelete: SetNull)
  photos  TripMemoryPhoto[]
  shares  TripMemoryShare[]

  @@index([tripId])
  @@index([authorTravelerId])
  @@map("trip_memories")
}

model TripMemoryPhoto {
  id          String @id @default(uuid())
  memoryId    String
  storagePath String
  publicUrl   String
  sortOrder   Int    @default(0)
  width       Int?
  height      Int?

  memory TripMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@map("trip_memory_photos")
}

model TripMemoryShare {
  id                String   @id @default(uuid())
  memoryId          String
  sentByTravelerId  String
  recipientEmail    String
  sentAt            DateTime @default(now())
  providerMessageId String?

  memory TripMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  sentBy Traveler   @relation("TripMemoryShareSender", fields: [sentByTravelerId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@map("trip_memory_shares")
}

model TripDayExperience {
  id            String                   @id @default(uuid())
  tripDayId     String
  hikeId        String?
  diningId      String?
  attractionId  String?
  concertId     String?
  sportId       String?
  adventureId   String?
  cruiseId      String?
  orderIndex    Int                      @default(0)
  startTime     String?
  endTime       String?
  status        TripDayExperienceStatus  @default(PLANNED)
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tripDay    TripDay     @relation(fields: [tripDayId], references: [id], onDelete: Cascade)
  hike       Hike?       @relation(fields: [hikeId], references: [id], onDelete: SetNull)
  dining     Dining?     @relation(fields: [diningId], references: [id], onDelete: SetNull)
  attraction Attraction? @relation(fields: [attractionId], references: [id], onDelete: SetNull)
  concert    Concert?    @relation(fields: [concertId], references: [id], onDelete: SetNull)
  sport      Sport?      @relation(fields: [sportId], references: [id], onDelete: SetNull)
  adventure  Adventure?  @relation(fields: [adventureId], references: [id], onDelete: SetNull)
  cruise     Cruise?     @relation(fields: [cruiseId], references: [id], onDelete: SetNull)

  @@index([tripDayId])
  @@index([hikeId])
  @@index([diningId])
  @@index([attractionId])
  @@index([concertId])
  @@index([sportId])
  @@index([adventureId])
  @@index([cruiseId])
}

model Sport {
  id        String    @id @default(uuid())
  name      String
  venue     String?
  cityId    String?
  eventDate DateTime?
  url       String?
  imageUrl  String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById       String?
  wishlistId        String?
  savedByTravelerId String?

  city           City?               @relation(fields: [cityId], references: [id], onDelete: SetNull)
  tripDayExperiences TripDayExperience[]
  createdBy      Traveler?           @relation("SportAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  savedBy        Traveler?           @relation("SportSavedBy", fields: [savedByTravelerId], references: [id], onDelete: SetNull)
  wishlist       Wishlist?           @relation(fields: [wishlistId], references: [id], onDelete: SetNull)

  @@index([cityId])
  @@index([eventDate])
  @@index([createdById])
  @@index([wishlistId])
  @@index([savedByTravelerId])
}

model Adventure {
  id          String   @id @default(uuid())
  name        String
  category    String?
  cityId      String?
  durationMin Int?
  url         String?
  imageUrl    String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById       String?
  wishlistId        String?
  savedByTravelerId String?

  city               City?               @relation(fields: [cityId], references: [id], onDelete: SetNull)
  tripDayExperiences TripDayExperience[]
  createdBy          Traveler?           @relation("AdventureAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  savedBy            Traveler?           @relation("AdventureSavedBy", fields: [savedByTravelerId], references: [id], onDelete: SetNull)
  wishlist           Wishlist?           @relation(fields: [wishlistId], references: [id], onDelete: SetNull)

  @@index([cityId])
  @@index([createdById])
  @@index([wishlistId])
  @@index([savedByTravelerId])
}

// Destination — bolts to City (first-class), not string; trip can have many
model Destination {
  id      String  @id @default(uuid())
  tripId  String
  cityId  String
  name    String? // e.g. "Virginia Beach leg", "NYC stop"
  state   String? // optional override
  country String? // optional override
  order   Int     @default(0) // for multi-city order

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city City @relation(fields: [cityId], references: [id], onDelete: Restrict)

  @@index([tripId])
  @@index([cityId])
}

model Lodging {
  id                   String    @id @default(uuid())
  tripId               String?   @unique // legacy; prefer day-level lodging on TripDayExperience
  tripWellEnterpriseId String?   // optional scope for reusable artifact
  title                String    // hotel / property display name
  chain                String?   // hotel chain affiliation
  lodgingType          LodgingType?
  amenities            Json?     // flexible map, e.g. { "pool": true, "gym": true }
  nightlyRate          Decimal?  @db.Decimal(10, 2)
  currency             String?   // ISO 4217, e.g. USD
  address              String?   // full formatted line(s) for display
  streetAddress        String?
  city                 String?
  state                String?
  postalCode           String?
  countryCode          String?   // ISO 3166-1 alpha-2
  defaultCheckInTime   String?   // e.g. "15:00" local convention
  defaultCheckOutTime  String?
  website              String?
  phone                String?
  googlePlaceId        String?
  imageUrl             String?
  rating               Float?
  lat                  Float?
  lng                  Float?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  trip            Trip?             @relation("TripLodging", fields: [tripId], references: [id], onDelete: Cascade)
  tripWellEnterprise TripWellEnterprise? @relation("EnterpriseLodging", fields: [tripWellEnterpriseId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([tripWellEnterpriseId])
  @@index([city, state])
}

model Dining {
  id                  String    @id @default(uuid())
  tripId              String?   // legacy; prefer ItineraryItem.diningId
  tripWellEnterpriseId String?
  cityId              String?   // city catalogue scope (discover flow)
  title               String
  category            String?
  address             String?
  phone               String?
  website             String?
  googlePlaceId       String?   @unique
  imageUrl            String?
  rating              Float?
  lat                 Float?
  lng                 Float?
  description         String?   @db.Text
  metadata            Json?
  distanceFromLodging Float?
  driveTimeMinutes    Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  createdById         String?
  wishlistId          String?
  savedByTravelerId   String?

  trip                Trip?     @relation("TripDining", fields: [tripId], references: [id], onDelete: Cascade)
  tripWellEnterprise  TripWellEnterprise? @relation("EnterpriseDining", fields: [tripWellEnterpriseId], references: [id], onDelete: SetNull)
  city                City?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  tripDayExperiences  TripDayExperience[]
  createdBy           Traveler? @relation("DiningAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  savedBy             Traveler? @relation("DiningSavedBy", fields: [savedByTravelerId], references: [id], onDelete: SetNull)
  wishlist            Wishlist? @relation(fields: [wishlistId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([tripWellEnterpriseId])
  @@index([cityId])
  @@index([createdById])
  @@index([wishlistId])
  @@index([savedByTravelerId])
}

model Attraction {
  id                   String    @id @default(uuid())
  tripId               String?   // legacy; prefer ItineraryItem.attractionId or stuffToDoId
  tripWellEnterpriseId String?
  cityId               String?   // city catalogue scope (discover flow)
  title                String
  category             String?
  address              String?
  phone                String?
  website              String?
  googlePlaceId        String?   @unique
  imageUrl             String?
  rating               Float?
  lat                  Float?
  lng                  Float?
  description          String?   @db.Text
  metadata             Json?
  distanceFromLodging  Float?
  driveTimeMinutes     Int?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  createdById          String?
  wishlistId           String?
  savedByTravelerId    String?

  trip                Trip?     @relation("TripAttractions", fields: [tripId], references: [id], onDelete: Cascade)
  tripWellEnterprise  TripWellEnterprise? @relation("EnterpriseAttractions", fields: [tripWellEnterpriseId], references: [id], onDelete: SetNull)
  city                City?     @relation(fields: [cityId], references: [id], onDelete: SetNull)
  tripDayExperiences  TripDayExperience[]
  createdBy           Traveler? @relation("AttractionAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  savedBy             Traveler? @relation("AttractionSavedBy", fields: [savedByTravelerId], references: [id], onDelete: SetNull)
  wishlist            Wishlist? @relation(fields: [wishlistId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([tripWellEnterpriseId])
  @@index([cityId])
  @@index([createdById])
  @@index([wishlistId])
  @@index([savedByTravelerId])
}

// Stuff-to-do catalogue — independent, keyed by city + season (bolt-on from itinerary)
model StuffToDoItem {
  id          String        @id @default(uuid())
  cityId      String
  season      String        // spring | summer | fall | winter | any
  type        StuffToDoType
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@index([cityId])
  @@index([cityId, season])
}

// Concert — first-class event (artist, venue, city, date); can bolt to itinerary
model Concert {
  id          String    @id @default(uuid())
  name        String    // e.g. "Noah Kahan"
  artist      String?
  venue       String?
  cityId      String?
  eventDate   DateTime?
  url         String?
  imageUrl    String?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById        String?
  wishlistId         String?
  savedByTravelerId  String?

  city               City?               @relation(fields: [cityId], references: [id], onDelete: SetNull)
  tripDayExperiences TripDayExperience[]
  createdBy          Traveler?           @relation("ConcertAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  savedBy            Traveler?           @relation("ConcertSavedBy", fields: [savedByTravelerId], references: [id], onDelete: SetNull)
  wishlist           Wishlist?           @relation(fields: [wishlistId], references: [id], onDelete: SetNull)

  @@index([cityId])
  @@index([eventDate])
  @@index([createdById])
  @@index([wishlistId])
  @@index([savedByTravelerId])
}

// Hike — first-class activity (trail/place, city, difficulty, distance); can bolt to itinerary
model Hike {
  id          String   @id @default(uuid())
  name        String   // e.g. "Eagle Rock Loop", "Griffith Peak"
  trailOrPlace String?  // trail name or place name
  createdById String?   // author Traveler id; null = legacy/seed (shared catalogue)
  cityId      String?
  difficulty  String?   // e.g. "easy", "moderate", "hard"
  distanceMi  Float?   // distance in miles
  durationMin Int?     // estimated duration minutes
  routeType   String?  // out_and_back | loop | point_to_point | lollipop
  trailheadLat  Float?
  trailheadLng  Float?
  nearestTown   String?
  sourcePaste   String? @db.Text
  url         String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wishlistId        String?
  savedByTravelerId String?

  city               City?               @relation(fields: [cityId], references: [id], onDelete: SetNull)
  createdBy          Traveler?           @relation("HikeAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  savedBy            Traveler?           @relation("HikeSavedBy", fields: [savedByTravelerId], references: [id], onDelete: SetNull)
  wishlist           Wishlist?           @relation(fields: [wishlistId], references: [id], onDelete: SetNull)
  tripDayExperiences TripDayExperience[]

  @@index([cityId])
  @@index([createdById])
  @@index([wishlistId])
  @@index([savedByTravelerId])
}

// Cruise — reusable catalogue sailing (ship, line, departure); trip-specific dates live on TripDay / TripDayExperience.
model Cruise {
  id                          String   @id @default(uuid())
  name                        String
  shipName                    String?
  cruiseLine                  String?
  departingFrom               String?
  cityId                      String?
  baseCostPerRoom             Float?
  baseCostPerGuest            Float?
  currency                    String?  @default("USD")
  amenities                   String?  @db.Text
  onboardEntertainmentSummary String?  @db.Text
  url                         String?
  notes                       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById       String?
  wishlistId        String?
  savedByTravelerId String?

  city               City?               @relation(fields: [cityId], references: [id], onDelete: SetNull)
  createdBy          Traveler?           @relation("CruiseAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  savedBy            Traveler?           @relation("CruiseSavedBy", fields: [savedByTravelerId], references: [id], onDelete: SetNull)
  wishlist           Wishlist?           @relation(fields: [wishlistId], references: [id], onDelete: SetNull)
  tripDayExperiences TripDayExperience[]

  @@index([cityId])
  @@index([createdById])
  @@index([wishlistId])
  @@index([savedByTravelerId])
}

model LogisticItem {
  id         String   @id @default(uuid())
  tripId     String
  title      String
  detail     String?
  isComplete Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model PackItem {
  id        String   @id @default(uuid())
  tripId    String
  title     String
  isPacked  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

// TripCrew Membership - Junction table (matching GoFast RunCrewMembership pattern)
model TripCrewMember {
  id         String @id @default(uuid())
  tripCrewId String
  travelerId String // ATHLETE-FIRST: Foreign key to Traveler

  // Timestamps
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tripCrew TripCrew @relation(fields: [tripCrewId], references: [id], onDelete: Cascade)
  traveler Traveler @relation("TravelerTripCrewMemberships", fields: [travelerId], references: [id], onDelete: Cascade)

  @@unique([tripCrewId, travelerId]) // Prevent duplicate memberships
  @@index([tripCrewId])
  @@index([travelerId])
  @@map("trip_crew_members")
}

// TripCrew Roles - Junction table for admin/manager roles (matching GoFast RunCrewManager pattern)
model TripCrewRole {
  id         String @id @default(uuid())
  tripCrewId String
  travelerId String
  role       String // "admin" | "manager"

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations
  tripCrew TripCrew @relation(fields: [tripCrewId], references: [id], onDelete: Cascade)
  traveler Traveler @relation("TravelerTripCrewRoles", fields: [travelerId], references: [id], onDelete: Cascade)

  @@unique([tripCrewId, travelerId])
  @@index([tripCrewId])
  @@index([travelerId])
  @@map("trip_crew_roles")
}

