rules_version = '2';

// Deploy in Firebase Console → Storage → Rules.
// Authenticated users may write only under trip-memories/{tripId}/{memoryId}/...
// Tighten further by matching tripId to a server-owned claim if you add custom claims later.

service firebase.storage {
  match /b/{bucket}/o {
    match /trip-memories/{tripId}/{memoryId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 11 * 1024 * 1024
                   && request.resource.contentType.matches('image/jpeg|image/png|image/webp');
    }
    match /memories/{memoryId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 11 * 1024 * 1024
                   && request.resource.contentType.matches('image/jpeg|image/png|image/webp');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
