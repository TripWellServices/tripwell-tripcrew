# Database (see Prisma docs)
DATABASE_URL="postgresql://..."

# Firebase Admin — server-side verification of ID tokens (hydrate, etc.). Same service account as GoFast.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# PEM with \n escaped as literal backslash-n in .env
FIREBASE_PRIVATE_KEY=

# TripWellEnterprise row id this deployment uses (artifacts default to this on create).
# Defaults to tripwell-enterprises-master-container if unset.
TRIPWELL_ENTERPRISE_ID=

# Optional: AI hike paste parsing (/api/hikes/parse, gpt-4o)
OPENAI_API_KEY=
