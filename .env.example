# Database (see Prisma docs)
DATABASE_URL="postgresql://..."
DATABASE_PRISMA_DATABASE_URL="prisma+postgres://..."
# Direct Postgres URL for `prisma migrate dev` shadow replay (separate empty DB). Not used at runtime.
SHADOW_DATABASE_URL="postgresql://..."

# Client Firebase: hardcoded in lib/firebaseClient.ts (IgniteBd-Next-combine pattern); no NEXT_PUBLIC_* needed.

# Firebase Admin — server-side ID token verification. Required on Vercel (VERCEL=1).
# Local dev: omit and use `gcloud auth application-default login`, or set one of the options below.
# Option A (recommended on Vercel): full service account JSON. Legacy alias: FIREBASE_SERVICE_ACCOUNT_JSON.
FIREBASE_SERVICE_ACCOUNT=
#
# Option B: three variables from the same JSON.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# TripWellEnterprise PK — optional override (GoFast-style default is in code: tripwell-enterprises-master-container).
TRIPWELL_ENTERPRISE_ID=

# TripWellCompany HQ origin — CORS for /api/company/* routes
NEXT_PUBLIC_COMPANY_APP_URL="http://localhost:3000"

# Optional: Google Places / Maps — hotel search, essentials, dining/attraction hydrate.
# Either name works; NEXT_PUBLIC_* is required for in-browser Maps autocomplete.
GOOGLE_PLACES_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: AI hike paste parsing (/api/hikes/parse, gpt-4o)
OPENAI_API_KEY=
