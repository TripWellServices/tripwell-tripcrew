# Database (see Prisma docs)
DATABASE_URL="postgresql://..."

# Firebase Admin — server-side ID token verification (/api/auth/hydrate, /api/traveler/*).
# Option A (recommended): full JSON from Firebase Console → Project settings → Service accounts → Generate new private key.
#    Single line is fine on Vercel. Legacy alias: FIREBASE_SERVICE_ACCOUNT_JSON (same value).
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
FIREBASE_SERVICE_ACCOUNT=
#
# Option B: three variables (project_id, client_email, private_key from the same JSON).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# TripWellEnterprise row id this deployment uses (artifacts default to this on create).
# Defaults to tripwell-enterprises-master-container if unset.
TRIPWELL_ENTERPRISE_ID=

# Optional: AI hike paste parsing (/api/hikes/parse, gpt-4o)
OPENAI_API_KEY=
