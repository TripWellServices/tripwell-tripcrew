# Database (see Prisma docs)
DATABASE_URL="postgresql://..."

# Firebase Admin — server-side ID token verification (/api/auth/hydrate, /api/traveler/*).
# Option A (easiest on Vercel): paste the entire JSON from Firebase Console → Project settings → Service accounts → Generate new private key.
#    Single line is fine; keep quotes if your host requires them.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
#
# Option B: three variables (map from the same JSON: project_id, client_email, private_key).
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=   # PEM; use literal \n for newlines in .env
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# TripWellEnterprise row id this deployment uses (artifacts default to this on create).
# Defaults to tripwell-enterprises-master-container if unset.
TRIPWELL_ENTERPRISE_ID=

# Optional: AI hike paste parsing (/api/hikes/parse, gpt-4o)
OPENAI_API_KEY=
